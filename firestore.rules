rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Tier B (Member): email-verified AND has a Blueprint. Blueprint doc id is
    // the user's uid (one Blueprint per user), so presence is checkable here.
    function isVerifiedMember() {
      return isSignedIn() &&
             request.auth.token.email_verified == true &&
             exists(/databases/$(database)/documents/resumes/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "petrodeksystems@gmail.com" ||
        request.auth.token.email == "esraigroup@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             (!('photoURL' in data.keys()) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2097152)) &&
             (!('bio' in data.keys()) || data.bio == null || (data.bio is string && data.bio.size() <= 5000)) &&
             (!('industrySegment' in data.keys()) || data.industrySegment == null || (data.industrySegment is string && data.industrySegment.size() <= 128)) &&
             (!('company' in data.keys()) || data.company == null || (data.company is string && data.company.size() <= 256)) &&
             (!('jobTitle' in data.keys()) || data.jobTitle == null || (data.jobTitle is string && data.jobTitle.size() <= 256)) &&
             (!('companyId' in data.keys()) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 128)) &&
             (!('isPro' in data.keys()) || data.isPro is bool) &&
             (!('isFounder' in data.keys()) || data.isFounder is bool) &&
             (!('founderSince' in data.keys()) || data.founderSince == null || data.founderSince is timestamp) &&
             (!('isPublic' in data.keys()) || data.isPublic is bool) &&
             (!('aiUsage' in data.keys()) || data.aiUsage is map) &&
             (!('skills' in data.keys()) || data.skills is list) &&
             (!('badges' in data.keys()) || data.badges is list) &&
             (!('profileLabels' in data.keys()) || data.profileLabels is map) &&
             (!('socialLinks' in data.keys()) || data.socialLinks is map) &&
             (!('savedJobs' in data.keys()) || data.savedJobs is list) &&
             (!('isVerifiedByCompany' in data.keys()) || data.isVerifiedByCompany is bool) &&
             (!('verifiedByCompanyId' in data.keys()) || data.verifiedByCompanyId is string) &&
             (!('verifiedByCompanyName' in data.keys()) || data.verifiedByCompanyName is string) &&
             (!('verifiedByUid' in data.keys()) || data.verifiedByUid is string) &&
             (!('verifiedAt' in data.keys()) || data.verifiedAt is timestamp || data.verifiedAt == null) &&
             (!('updatedAt' in data.keys()) || data.updatedAt is timestamp || data.updatedAt == null) &&
             data.uid == request.auth.uid; // Identity Integrity
    }

    function isValidEndorsement(data) {
      return data.keys().hasAll(['targetUid', 'endorserUid', 'skill', 'createdAt']) &&
             data.endorserUid == request.auth.uid &&
             data.targetUid is string &&
             data.skill is string &&
             data.createdAt == request.time;
    }

    function isValidRecommendation(data) {
      return data.keys().hasAll(['targetUid', 'recommenderUid', 'traits', 'createdAt']) &&
             data.recommenderUid == request.auth.uid &&
             data.targetUid is string &&
             data.traits is list &&
             data.createdAt == request.time;
    }

    function isValidResume(data) {
      return data.keys().hasAll(['userUid', 'fullName']) &&
             data.userUid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 256 &&
             // Legacy category fields — optional now (taxonomy replaces them).
             (!('categoryId' in data.keys()) || data.categoryId == null || data.categoryId is string) &&
             (!('categoryName' in data.keys()) || data.categoryName == null || data.categoryName is string) &&
             (!('subCategoryId' in data.keys()) || data.subCategoryId == null || data.subCategoryId is string) &&
             (!('subCategoryName' in data.keys()) || data.subCategoryName == null || data.subCategoryName is string) &&
             // Taxonomy fields (Phase 2a). IDs reference /taxonomy nodes.
             (!('taxRole' in data.keys()) || data.taxRole == null || data.taxRole is string) &&
             (!('taxFamilyId' in data.keys()) || data.taxFamilyId == null || data.taxFamilyId is string) &&
             (!('taxDomainId' in data.keys()) || data.taxDomainId == null || data.taxDomainId is string) &&
             (!('taxSeniority' in data.keys()) || data.taxSeniority == null || data.taxSeniority is string) &&
             (!('taxIndustryIds' in data.keys()) || data.taxIndustryIds == null || data.taxIndustryIds is list) &&
             (!('taxStandardIds' in data.keys()) || data.taxStandardIds == null || data.taxStandardIds is list) &&
             (!('taxCompetencyIds' in data.keys()) || data.taxCompetencyIds == null || data.taxCompetencyIds is list) &&
             (!('taxCertificationIds' in data.keys()) || data.taxCertificationIds == null || data.taxCertificationIds is list) &&
             (!('taxEquipmentIds' in data.keys()) || data.taxEquipmentIds == null || data.taxEquipmentIds is list) &&
             (!('educationLevel' in data.keys()) || data.educationLevel == null || data.educationLevel is string) &&
             (!('yearsExperience' in data.keys()) || data.yearsExperience == null || data.yearsExperience is number) &&
             (!('currentCity' in data.keys()) || data.currentCity == null || (data.currentCity is string && data.currentCity.size() <= 128)) &&
             (!('preferredLocations' in data.keys()) || data.preferredLocations == null || data.preferredLocations is list);
    }

    function isValidNews(data) {
      return data.keys().hasAll(['url', 'title', 'createdAt']) &&
             data.url is string && data.url.size() <= 2048 &&
             data.title is string && data.title.size() <= 512 &&
             data.createdAt == request.time &&
             (!('description' in data.keys()) || data.description == null || (data.description is string && data.description.size() <= 2000)) &&
             (!('image' in data.keys()) || data.image == null || (data.image is string && data.image.size() <= 2048)) &&
             (!('source' in data.keys()) || data.source == null || (data.source is string && data.source.size() <= 128)) &&
             (!('authorUid' in data.keys()) || data.authorUid == null || (data.authorUid is string && data.authorUid.size() <= 128));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['content', 'authorUid', 'createdAt']) &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorUid == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is string) &&
             (!('authorName' in data.keys()) || data.authorName == null || (data.authorName is string && data.authorName.size() <= 512)) &&
             (!('authorPhoto' in data.keys()) || data.authorPhoto == null || (data.authorPhoto is string && data.authorPhoto.size() <= 2097152)) &&
             (!('authorJobTitle' in data.keys()) || data.authorJobTitle == null || (data.authorJobTitle is string && data.authorJobTitle.size() <= 512)) &&
             (!('authorEmail' in data.keys()) || data.authorEmail == null || (data.authorEmail is string && data.authorEmail.size() <= 512)) &&
             (!('image' in data.keys()) || data.image == null || (data.image is string && data.image.size() <= 10485760)) &&
             (!('likesCount' in data.keys()) || data.likesCount is number) &&
             (!('commentsCount' in data.keys()) || data.commentsCount is number) &&
             (!('isRepost' in data.keys()) || data.isRepost is bool) &&
             (!('originalAuthor' in data.keys()) || data.originalAuthor == null || (data.originalAuthor is string && data.originalAuthor.size() <= 512)) &&
             (!('companyId' in data.keys()) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 128)) &&
             (!('companyName' in data.keys()) || data.companyName == null || (data.companyName is string && data.companyName.size() <= 512)) &&
             (!('companyLogo' in data.keys()) || data.companyLogo == null || (data.companyLogo is string && data.companyLogo.size() <= 2097152)) &&
             (!('video' in data.keys()) || data.video == null || (data.video is map)) &&
             (!('reactions' in data.keys()) || data.reactions is map) &&
             (!('updatedAt' in data.keys()) || data.updatedAt == request.time);
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'organizerUid']) &&
             data.title is string && data.title.size() <= 512 &&
             data.organizerUid == request.auth.uid &&
             (!('description' in data.keys()) || data.description == null || data.description is string) &&
             (!('location' in data.keys()) || data.location == null || data.location is string) &&
             (!('type' in data.keys()) || data.type == null || data.type is string) &&
             (!('time' in data.keys()) || data.time == null || data.time is string) &&
             (!('endDate' in data.keys()) || data.endDate == null || data.endDate is string) &&
             (!('endTime' in data.keys()) || data.endTime == null || data.endTime is string) &&
             (!('categoryId' in data.keys()) || data.categoryId == null || data.categoryId is string) &&
             (!('categoryName' in data.keys()) || data.categoryName == null || data.categoryName is string) &&
             (!('categoryIds' in data.keys()) || data.categoryIds == null || data.categoryIds is list) &&
             (!('image' in data.keys()) || data.image == null || data.image is string) &&
             (!('imageUrl' in data.keys()) || data.imageUrl == null || data.imageUrl is string) &&
             (!('ctaText' in data.keys()) || data.ctaText == null || data.ctaText is string) &&
             (!('ctaUrl' in data.keys()) || data.ctaUrl == null || data.ctaUrl is string) &&
             (!('companyId' in data.keys()) || data.companyId == null || data.companyId is string) &&
             (!('companyName' in data.keys()) || data.companyName == null || data.companyName is string) &&
             (!('companyLogo' in data.keys()) || data.companyLogo == null || data.companyLogo is string) &&
             (!('isFeatured' in data.keys()) || data.isFeatured == null || data.isFeatured is bool) &&
             (!('createdAt' in data.keys()) || data.createdAt is timestamp);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['content', 'authorUid', 'createdAt']) &&
             data.content is string && data.content.size() <= 5000 &&
             data.authorUid == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is string) &&
             (!('authorJobTitle' in data.keys()) || data.authorJobTitle == null || (data.authorJobTitle is string && data.authorJobTitle.size() <= 512)) &&
             (!('authorName' in data.keys()) || data.authorName == null || (data.authorName is string && data.authorName.size() <= 512)) &&
             (!('authorPhoto' in data.keys()) || data.authorPhoto == null || (data.authorPhoto is string && data.authorPhoto.size() <= 2097152)) &&
             (!('quote' in data.keys()) || data.quote == null || (
               data.quote is map && 
               data.quote.keys().hasAll(['authorName', 'content']) &&
               data.quote.authorName is string &&
               data.quote.content is string
             ));
    }

    function isValidSettings(data) {
      return data.keys().hasAny(['primaryColor', 'secondaryColor', 'accentColor', 'logoUrl', 'logoUrlDark', 'siteName', 'displayMode', 'updatedAt',
                                 'industry', 'domain', 'role', 'standards', 'competencies', 'certifications', 'equipment', 'seniority',
                                 'educationPenalty', 'experiencePenalty', 'mustHaveMissingFactor']);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['targetId', 'targetType', 'reason', 'reporterUid', 'createdAt']) &&
             data.targetId is string &&
             data.targetType in ['post', 'comment', 'profile'] &&
             data.reason is string && data.reason.size() <= 2000 &&
             data.reporterUid == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidProductRecommendation(data) {
      return data.keys().hasAll(['companyId', 'productName', 'userUid', 'createdAt']) &&
             data.userUid == request.auth.uid &&
             data.companyId is string &&
             data.productName is string &&
             data.createdAt == request.time;
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'categoryId']) &&
             data.name is string && data.name.size() <= 256 &&
             data.categoryId is string &&
             (!('aboutUs' in data.keys()) || data.aboutUs is string) &&
             (!('address' in data.keys()) || data.address is string) &&
             (!('heroImage' in data.keys()) || data.heroImage is string) &&
             (!('isFeatured' in data.keys()) || data.isFeatured is bool) &&
             (!('plan' in data.keys()) || data.plan == null || data.plan in ['free', 'premium']) &&
             (!('planSince' in data.keys()) || data.planSince == null || data.planSince is timestamp) &&
             (!('products' in data.keys()) || data.products is list);
    }

    function isValidCompanyClaim(data) {
      return data.keys().hasAll(['companyId', 'userUid', 'justification']) &&
             data.companyId is string &&
             data.userUid == request.auth.uid &&
             data.justification is string && data.justification.size() <= 2000;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['title', 'description', 'companyName', 'creatorUid', 'creatorEmail']) &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.companyName is string && data.companyName.size() <= 256 &&
             data.creatorUid == request.auth.uid &&
             data.creatorEmail is string &&
             (!('companyId' in data.keys()) || data.companyId == null || data.companyId is string) &&
             (!('companyLogo' in data.keys()) || data.companyLogo == null || data.companyLogo is string) &&
             (!('location' in data.keys()) || data.location == null || data.location is string) &&
             (!('salary' in data.keys()) || data.salary == null || data.salary is string) &&
             (!('type' in data.keys()) || data.type in ["Full-time", "Part-time", "Contract", "Freelance", "Internship"]) &&
             (!('status' in data.keys()) || data.status in ["open", "closed"]) &&
             (!('categoryIds' in data.keys()) || data.categoryIds == null || data.categoryIds is list) &&
             (!('taxRole' in data.keys()) || data.taxRole == null || data.taxRole is string) &&
             (!('taxDomainId' in data.keys()) || data.taxDomainId == null || data.taxDomainId is string) &&
             (!('taxSeniority' in data.keys()) || data.taxSeniority == null || data.taxSeniority is string) &&
             (!('taxIndustryIds' in data.keys()) || data.taxIndustryIds == null || data.taxIndustryIds is list) &&
             (!('taxStandardIds' in data.keys()) || data.taxStandardIds == null || data.taxStandardIds is list) &&
             (!('taxCompetencyIds' in data.keys()) || data.taxCompetencyIds == null || data.taxCompetencyIds is list) &&
             (!('taxCertificationIds' in data.keys()) || data.taxCertificationIds == null || data.taxCertificationIds is list) &&
             (!('taxEquipmentIds' in data.keys()) || data.taxEquipmentIds == null || data.taxEquipmentIds is list) &&
             (!('taxMustHaveIds' in data.keys()) || data.taxMustHaveIds == null || data.taxMustHaveIds is list) &&
             (!('minEducation' in data.keys()) || data.minEducation == null || data.minEducation is string) &&
             (!('minYearsExperience' in data.keys()) || data.minYearsExperience == null || data.minYearsExperience is number) &&
             (!('createdAt' in data.keys()) || data.createdAt is timestamp);
    }

    // Matches are admin-created suggestions linking a resume to a job.
    // Individuals can accept/reject; company owners can mark hired/passed.
    function isValidJobMatch(data) {
      return data.keys().hasAll(['jobId', 'jobTitle', 'companyId', 'companyName', 'companyOwnerUid',
                                  'resumeId', 'userUid', 'userName', 'status', 'createdAt']) &&
             data.jobId is string &&
             data.jobTitle is string && data.jobTitle.size() <= 256 &&
             data.companyId is string &&
             data.companyName is string && data.companyName.size() <= 256 &&
             data.companyOwnerUid is string &&
             data.resumeId is string &&
             data.userUid is string &&
             data.userName is string && data.userName.size() <= 256 &&
             data.status in ['suggested', 'accepted', 'rejected', 'hired', 'passed', 'applied'] &&
             data.createdAt is timestamp &&
             (!('adminUid' in data.keys()) || data.adminUid == null || data.adminUid is string) &&
             (!('adminNote' in data.keys()) || data.adminNote == null || data.adminNote is string) &&
             (!('coverNote' in data.keys()) || data.coverNote == null || data.coverNote is string) &&
             (!('score' in data.keys()) || data.score == null || data.score is number) &&
             (!('updatedAt' in data.keys()) || data.updatedAt is timestamp);
    }

    // An applicant creating their OWN application: must be for themselves,
    // status 'applied', no self-assigned score, and an admin identity absent.
    function isValidSelfApplication(data) {
      return isValidJobMatch(data) &&
             data.userUid == request.auth.uid &&
             data.status == 'applied' &&
             (!('score' in data.keys()) || data.score == null) &&
             (!('adminUid' in data.keys()) || data.adminUid == null);
    }

    // Talent Bank taxonomy nodes (docs/TALENT_BANK_PHASE0.md).
    // Doc IDs are stable slugs (e.g. role-terminal-operator); referenced by
    // resumes and jobs, so deletes are admin-only and should be rare.
    function isValidTaxonomyNode(data) {
      return data.keys().hasAll(['type', 'name', 'level', 'order']) &&
             data.type in ['industry', 'vertical', 'domain', 'family', 'role', 'standard', 'competency', 'certification', 'equipment'] &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.level is number && data.level >= 1 && data.level <= 3 &&
             data.order is number && data.order >= 0 &&
             (!('id' in data.keys()) || data.id == null || data.id is string) &&
             (!('parentId' in data.keys()) || data.parentId == null || data.parentId is string) &&
             (!('aliases' in data.keys()) || data.aliases == null || data.aliases is list) &&
             (!('note' in data.keys()) || data.note == null || data.note is string);
    }

    function isValidConnection(data) {
      return data.keys().hasAll(['userIds', 'status', 'requesterId', 'createdAt']) &&
             data.userIds is list && data.userIds.size() == 2 &&
             request.auth.uid in data.userIds &&
             data.requesterId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.createdAt == request.time;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'creatorUid', 'createdAt']) &&
             data.name is string && data.name.size() <= 128 &&
             data.creatorUid == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('description' in data.keys()) || data.description is string) &&
             (!('iconUrl' in data.keys()) || data.iconUrl is string) &&
             (!('coverUrl' in data.keys()) || data.coverUrl is string) &&
             (!('admins' in data.keys()) || data.admins is list) &&
             (!('creatorName' in data.keys()) || data.creatorName is string) &&
             (!('memberCount' in data.keys()) || data.memberCount is number) &&
             (!('status' in data.keys()) || data.status in ['pending', 'approved', 'rejected']) &&
             (!('isPrivate' in data.keys()) || data.isPrivate is bool);
    }

    function isValidGroupPost(data) {
      return data.keys().hasAll(['groupId', 'content', 'authorUid', 'createdAt']) &&
             data.groupId is string &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorUid == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is string) &&
             (!('authorName' in data.keys()) || data.authorName == null || (data.authorName is string && data.authorName.size() <= 512)) &&
             (!('authorPhoto' in data.keys()) || data.authorPhoto == null || (data.authorPhoto is string && data.authorPhoto.size() <= 2097152)) &&
             (!('authorJobTitle' in data.keys()) || data.authorJobTitle == null || (data.authorJobTitle is string && data.authorJobTitle.size() <= 512)) &&
             (!('likesCount' in data.keys()) || data.likesCount is number) &&
             (!('commentsCount' in data.keys()) || data.commentsCount is number) &&
             (!('companyId' in data.keys()) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 128)) &&
             (!('companyName' in data.keys()) || data.companyName == null || (data.companyName is string && data.companyName.size() <= 512)) &&
             (!('companyLogo' in data.keys()) || data.companyLogo == null || (data.companyLogo is string && data.companyLogo.size() <= 2097152)) &&
             (!('video' in data.keys()) || data.video is map) &&
             (!('image' in data.keys()) || data.image is string);
    }

    function isValidGroupMember(data) {
      return data.keys().hasAll(['groupId', 'userUid', 'role', 'joinedAt']) &&
             data.groupId is string &&
             data.userUid is string &&
             data.role in ['member', 'admin', 'creator', 'pending'] &&
             data.joinedAt is timestamp &&
             (!('status' in data.keys()) || data.status in ['pending', 'approved', 'rejected']) &&
             (!('userName' in data.keys()) || data.userName == null || data.userName is string) &&
             (!('userPhoto' in data.keys()) || data.userPhoto == null || data.userPhoto is string) &&
             (!('userJobTitle' in data.keys()) || data.userJobTitle == null || data.userJobTitle is string) &&
             (!('userCompany' in data.keys()) || data.userCompany == null || data.userCompany is string);
    }

    function isValidForumTopic(data) {
      return data.keys().hasAll(['title', 'categoryIds', 'authorUid', 'createdAt']) &&
             data.title is string && data.title.size() <= 512 &&
             data.authorUid == request.auth.uid &&
             data.createdAt == request.time &&
             data.categoryIds is list &&
             (!('authorName' in data.keys()) || data.authorName is string) &&
             (!('replyCount' in data.keys()) || data.replyCount is number);
    }

    function isValidForumPost(data) {
      return data.keys().hasAll(['topicId', 'content', 'authorUid', 'createdAt']) &&
             data.topicId is string &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorUid == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is string) &&
             (!('authorName' in data.keys()) || data.authorName == null || (data.authorName is string && data.authorName.size() <= 512)) &&
             (!('authorPhoto' in data.keys()) || data.authorPhoto == null || (data.authorPhoto is string && data.authorPhoto.size() <= 2097152));
    }

    function isValidEventAttendee(data) {
      return data.keys().hasAll(['eventId', 'userUid']) &&
             data.eventId is string &&
             data.userUid == request.auth.uid &&
             (!('userName' in data.keys()) || data.userName is string) &&
             (!('userPhoto' in data.keys()) || data.userPhoto is string) &&
             (!('companyName' in data.keys()) || data.companyName is string) &&
             (!('status' in data.keys()) || data.status in ['confirmed', 'interested']) &&
             (!('timestamp' in data.keys()) || data.timestamp == request.time);
    }


    function isConnectedToCompany(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
             get(/databases/$(database)/documents/users/$(uid)).data.get('companyId', '') != '';
    }

    function isGroupAdmin(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return request.auth.uid == group.creatorUid || request.auth.uid in group.admins;
    }

    function isGroupMember(groupId) {
      return exists(/databases/$(database)/documents/group_members/$(groupId + "_" + request.auth.uid));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'content', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.content is string && data.content.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isCompanyOwner(companyId) {
      return isSignedIn() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == request.auth.uid;
    }

    // --- Collection Rules ---

    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'targetId', 'targetType', 'createdAt']) &&
             isValidId(data.targetId) &&
             data.followerId is string &&
             data.targetType in ['member', 'company'] &&
             data.createdAt == request.time;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['likerId', 'targetId', 'targetType', 'createdAt']) &&
             isValidId(data.targetId) &&
             data.likerId is string &&
             data.targetType in ['member', 'company'] &&
             data.createdAt == request.time;
    }

    match /follows/{followId} {
      allow get: if isSignedIn() && isValidId(followId);
      allow list: if isSignedIn() && (resource.data.targetType in ['member', 'company']);
      allow create: if isSignedIn() && isValidId(followId) && isValidFollow(incoming()) && (
        incoming().followerId == request.auth.uid ||
        (incoming().targetType == 'company' && isCompanyOwner(incoming().targetId))
      );
      allow delete: if isSignedIn() && isValidId(followId) && (
        resource.data.followerId == request.auth.uid ||
        (resource.data.targetType == 'company' && isCompanyOwner(resource.data.targetId))
      );
    }

    match /likes/{likeId} {
      allow get: if isSignedIn() && isValidId(likeId);
      allow list: if isSignedIn() && (resource.data.targetType in ['member', 'company']);
      allow create: if isSignedIn() && isValidId(likeId) && isValidLike(incoming()) && (
        incoming().likerId == request.auth.uid ||
        (incoming().targetType == 'company' && isCompanyOwner(incoming().targetId))
      );
      allow delete: if isSignedIn() && isValidId(likeId) && (
        resource.data.likerId == request.auth.uid ||
        (resource.data.targetType == 'company' && isCompanyOwner(resource.data.targetId))
      );
    }

    match /connections/{connectionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(connectionId) && isValidConnection(incoming());
      allow update: if isValidId(connectionId) && isSignedIn() && (request.auth.uid in resource.data.userIds) &&
                    (!incoming().diff(existing()).affectedKeys().hasAny(['userIds', 'requesterId', 'createdAt'])) &&
                    (incoming().status in ['pending', 'accepted', 'rejected']);
      allow delete: if isSignedIn() && isValidId(connectionId) && (request.auth.uid in resource.data.userIds);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      // Messaging baseline: a verified member (B+) may start a chat they're a
      // participant in. Connection/match requirements are enforced in the app
      // (where the "Message" action only appears for connections or matched
      // company↔candidate pairs); B-tier gating here blocks spam at the rules
      // level. (Was previously isPro-only, which wrongly limited messaging to
      // premium users — see USER_TIERS.md.)
      allow create: if isVerifiedMember() &&
                    (request.auth.uid in incoming().participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isSignedIn() && 
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) && 
                      isValidMessage(incoming());
      }
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || isConnectedToCompany(request.auth.uid)) && isValidGroup(incoming());
      allow update: if isSignedIn() && (
                    ((isGroupAdmin(groupId) || isAdmin()) &&
                    isValidGroup(incoming()) &&
                    (!incoming().diff(existing()).affectedKeys().hasAny(['creatorUid', 'createdAt']))) ||
                    ((isAdmin() || isConnectedToCompany(request.auth.uid)) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['memberCount']) &&
                     (incoming().memberCount == existing().memberCount + 1 || incoming().memberCount == existing().memberCount - 1))
                  );
      allow delete: if isAdmin() || (isSignedIn() && existing().creatorUid == request.auth.uid);

      match /posts/{postId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn() && isGroupMember(groupId) && isValidGroupPost(incoming());
        allow update: if (isOwner(existing().authorUid) && isValidGroupPost(incoming())) || 
                        (isSignedIn() && isGroupMember(groupId) && incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'updatedAt'])) ||
                        isGroupAdmin(groupId) || isAdmin();
        allow delete: if isOwner(existing().authorUid) || isGroupAdmin(groupId) || isAdmin();

        match /comments/{commentId} {
          allow read: if isSignedIn() && isGroupMember(groupId);
          allow create: if isSignedIn() && isGroupMember(groupId) && isValidComment(incoming());
          allow delete: if isOwner(existing().authorUid) || isGroupAdmin(groupId) || isAdmin();
        }
      }
    }

    match /group_members/{memberId} {
      // memberId is groupId + "_" + userUid
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      (isAdmin() || isConnectedToCompany(request.auth.uid)) && 
                      isValidGroupMember(incoming()) &&
                      memberId == (incoming().groupId + "_" + incoming().userUid);
      allow update: if isSignedIn() && 
                      (isGroupAdmin(incoming().groupId) || isAdmin()) &&
                      isValidGroupMember(incoming());
      allow delete: if isSignedIn() && 
                      (isOwner(resource.data.userUid) || isGroupAdmin(resource.data.groupId) || isAdmin());
    }

    match /resumes/{resumeId} {
      allow read: if isSignedIn() && (resource.data.userUid == request.auth.uid || resource.data.isLocked == false || isAdmin());
      allow create: if isSignedIn() && isValidResume(incoming());
      allow update: if isOwner(existing().userUid) && isValidResume(incoming());
      allow delete: if isOwner(existing().userUid) || isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidReport(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /taxonomy/{nodeId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidTaxonomyNode(incoming());
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && (request.method == 'delete' || isValidCompany(incoming()));
    }

    match /company_categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /company_claims/{claimId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userUid == request.auth.uid);
      allow create: if isSignedIn() && isValidCompanyClaim(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Public for branding
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.token.email == "petrodeksystems@gmail.com" ||
        request.auth.token.email == "esraigroup@gmail.com"
      );
      allow write: if false; // Managed via console/backend
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(userId);
      allow update: if isValidId(userId) && (
                    (isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'industrySegment', 'company', 'companyId', 'jobTitle', 'aiUsage', 'isPublic', 'skills', 'profileLabels', 'socialLinks', 'updatedAt', 'email', 'uid', 'savedJobs', 'badges'])) ||
                    (isCompanyOwner(existing().companyId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['isVerifiedByCompany', 'verifiedByCompanyId', 'verifiedByCompanyName', 'verifiedAt', 'verifiedByUid'])) ||
                    isAdmin()
                  );
    }

    match /endorsements/{endorsementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidEndorsement(incoming());
      allow delete: if isOwner(existing().endorserUid) || isAdmin();
    }

    match /recommendations/{recommendationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRecommendation(incoming());
      allow update: if isOwner(existing().recommenderUid) && isValidRecommendation(incoming());
      allow delete: if isOwner(existing().recommenderUid) || isAdmin();
    }

    match /product_recommendations/{recommendationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProductRecommendation(incoming());
      allow delete: if isOwner(existing().userUid) || isAdmin();
    }

    match /news/{newsId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidNews(incoming());
      allow update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && isValidPost(incoming());
      allow update: if (isOwner(existing().authorUid) && 
                        isValidPost(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['content', 'image', 'updatedAt'])) ||
                      (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'reactions', 'updatedAt'])) ||
                      isAdmin();
      allow delete: if isOwner(existing().authorUid) || isAdmin();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && isValidComment(incoming());
      allow delete: if isOwner(existing().authorUid) || isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isSignedIn() && isConnectedToCompany(request.auth.uid))) && isValidEvent(incoming());
      allow update: if (isOwner(existing().organizerUid) && isValidEvent(incoming())) || isAdmin();
      allow delete: if (isOwner(existing().organizerUid) || isAdmin());
    }

    function isValidEventReminder(data) {
      return data.keys().hasAll(['eventId', 'userUid', 'eventName', 'eventDate']) &&
             data.userUid == request.auth.uid &&
             data.eventId is string &&
             data.eventName is string &&
             data.eventDate is string;
    }

    match /forum_topics/{topicId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && isValidForumTopic(incoming());
      allow update: if (isOwner(existing().authorUid) && isValidForumTopic(incoming())) || 
                      (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['replyCount', 'updatedAt'])) ||
                      isAdmin();
      
      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isVerifiedMember() && incoming().topicId == topicId && isValidForumPost(incoming());
        allow delete: if isOwner(existing().authorUid) || isAdmin();
      }

      // The frontend code (PostDetail.tsx) writes/reads from a /comments
      // subcollection. Define rules so those operations succeed.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().authorUid == request.auth.uid;
        allow update: if isOwner(existing().authorUid) || isAdmin();
        allow delete: if isOwner(existing().authorUid) || isAdmin();
      }
    }

    match /event_reminders/{reminderId} {
      allow read: if isSignedIn() && (resource.data.userUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidEventReminder(incoming());
      allow update: if isAdmin();
      allow delete: if isSignedIn() && (resource.data.userUid == request.auth.uid || isAdmin());
    }

    match /event_attendees/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidEventAttendee(incoming());
      allow delete: if isSignedIn() && (resource.data.userUid == request.auth.uid || isAdmin());
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      // Create restricted to admins OR owners of an admin-approved company.
      // The UI gate (isCompanyOwner) is not sufficient on its own — the rules
      // enforce it server-side so the API cannot be abused directly.
      allow create: if isSignedIn() && isValidJob(incoming()) && (
        isAdmin() ||
        (incoming().companyId is string && incoming().companyId.size() > 0 &&
         get(/databases/$(database)/documents/companies/$(incoming().companyId)).data.ownerUid == request.auth.uid &&
         get(/databases/$(database)/documents/companies/$(incoming().companyId)).data.status == 'approved')
      );
      allow update: if (isOwner(existing().creatorUid) && isValidJob(incoming())) || isAdmin();
      allow delete: if isOwner(existing().creatorUid) || isAdmin();
    }

    match /job_matches/{matchId} {
      // Admin sees all. Individuals see matches where they are the candidate.
      // Company owners see matches against their job listings.
      allow read: if isAdmin() ||
                  (isSignedIn() && resource.data.userUid == request.auth.uid) ||
                  (isSignedIn() && resource.data.companyOwnerUid == request.auth.uid);
      // Admins create matches (any status). Signed-in users may create their
      // OWN application (status 'applied', for themselves, no score) — this is
      // the candidate-initiated apply path.
      allow create: if (isAdmin() && isValidJobMatch(incoming())) ||
                       (isSignedIn() && isValidSelfApplication(incoming()));
      // Individual can accept/reject their own suggestion.
      // Company owner can mark a match hired/passed once individual has accepted.
      // Admin can change anything.
      allow update: if isAdmin() ||
                    (isSignedIn() && resource.data.userUid == request.auth.uid &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                     incoming().status in ['accepted', 'rejected']) ||
                    (isSignedIn() && resource.data.companyOwnerUid == request.auth.uid &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                     incoming().status in ['hired', 'passed']);
      allow delete: if isAdmin();
    }

    match /profile_views/{viewId} {
      // The viewed person reads views of themselves. Admin reads all.
      allow read: if isAdmin() ||
                  (isSignedIn() && resource.data.viewedUid == request.auth.uid);
      // A signed-in user records a view they performed (viewerUid is them).
      // Doc id is `${viewedUid}_${viewerUid}`; upsert refreshes the timestamp.
      allow create, update: if isSignedIn() &&
                    incoming().viewerUid == request.auth.uid &&
                    incoming().viewedUid is string &&
                    incoming().viewerUid != incoming().viewedUid;
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if isSignedIn(); // Allow mentions/triggers
      allow update: if isSignedIn() && resource.data.recipientUid == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
    }

    match /surveys/{surveyId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isSignedIn() && isConnectedToCompany(request.auth.uid)));
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['options', 'totalVotes', 'updatedAt'])) || isAdmin();
      
      match /votes/{voteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(voteId); // voteId is userId for uniqueness
      }
    }
  }
}
